{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "declaration": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "outDir": "dist"
  },
  "exclude": ["node_modules", "dist"]
}
