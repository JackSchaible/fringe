{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "declaration": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "outDir": "dist",
    "types": ["node"]
  },
  "exclude": ["node_modules", "dist"],
  "references": [{ "path": "./tsconfig.test.json" }]
}
